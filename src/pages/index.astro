---
import Layout from "@/layouts/Layout.astro";
import Button from "@/components/atoms/Button.astro";
import Service from "@/components/Service.astro";
import QuoteForm from "@/components/QuoteForm.astro";
import Carrousel from "@/components/Carrousel.astro";
import "@/styles/animations.css";
import { SERVICES } from "@/utils/content";

const companies = Array.from({ length: 8 }, (_, i) => i + 1);
---

<Layout>
  <!-- First view section with video -->
  <section class="relative h-[95vh] overflow-hidden">
    <video
      class="absolute inset-0 h-full w-full object-cover object-[15%]"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src="/video/inicio.webm" type="video/webm" />
      <source src="/video/inicio.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-black/60"></div>

    <div class="mx-layout absolute top-1/2 left-0 block w-3/4 -translate-y-[60%] md:w-1/2 lg:w-1/3">
      <h1 class="text-titles animate-fade-up mb-4 text-white delay-100">Hacemos realidad tus proyectos</h1>
      <h3 class="text-subtitles animate-fade-up mb-4 text-white delay-400">
        Expertos en servicios profesionales en el área de la construcción.
      </h3>
      <Button href="#contacto" class="fade-in-on-load">¡Cotiza ya!</Button>
    </div>
    <!-- Boton sobre nosotros -->
    <a
      href="#sobre-nosotros"
      class="animate-bounce-slow pause-on-hover absolute bottom-6 flex w-full flex-col items-center justify-center space-y-2 text-white delay-800"
    >
      <p class="drop-shadow-[0_0_6px_rgba(255,255,255,1)]">Sobre Nosotros</p>
      <img src="/icons/arrowdown.svg" alt="arrow down" />
    </a>
  </section>

  <!-- Trusted companies section -->
  <section class="mx-layout relative my-10 flex flex-col items-center justify-center text-center">
    <p class="text-paragraphs text-primary">
      Nuestros servicios han estado presentes en diferentes proyectos y empresas
    </p>
    <div class="mt-5 flex flex-row flex-wrap items-center justify-between gap-4">
      {
        companies.map((n) => (
          <img
            src={`/trusted_companies/${n}.png`}
            alt={`Compañia ${n}`}
            class="h-auto w-[20%] object-contain md:w-[10%]"
          />
        ))
      }
    </div>
  </section>

  <!-- Portfolio carrousel section -->
  <!-- <section id="sobre-nosotros" class="my-10 flex flex-col space-y-4 lg:flex-row lg:gap-15">
    <div class="flex w-full flex-col items-start justify-center space-y-6 px-5 md:px-8 lg:w-[30%] lg:px-0 lg:pl-18">
      <h2 class="text-primary">
        <span>
          Descubre nuestros<span></span>
          <p class="text-3xl font-bold">PROYECTOS COMPLETADOS</p>
        </span>
      </h2>
      <p class="text-paragraphs text-primary">
        Explora nuestra experiencia y soluciones en ingeniería y construcción a través de nuestro.
      </p>
      <Button href="/proyectos">Portafolio de proyectos</Button>
    </div>
    <div class="relative w-full px-5 md:px-8 lg:w-[65%] lg:px-0">
      <Carrousel />
    </div>
  </section> -->

  <!-- About us section -->
  <section class="mx-layout relative my-10 flex flex-col space-y-4 lg:flex-row lg:gap-15">
    <img src="/img/collage.webp" alt="Collage img" class="h-auto w-full lg:w-[45%]" />
    <div class="flex flex-col justify-center space-y-6">
      <h2 class="text-titles-2 text-primary">
        <span class="font-bold">Tu aliado estratégico</span> para ejecutar tus proyectos
      </h2>
      <p class="text-paragraphs text-primary">
        Somos una empresa salvadoreña con amplia experiencia en el sector de la construcción, especializada en
        soluciones integrales de ingeniería.
      </p>
      <div class="flex flex-col justify-center space-y-4">
        <p class="text-paragraphs text-primary flex items-center gap-2 font-medium">
          <i><img src="/icons/check.svg" alt="check icon" class="w-[80%]" /></i>Compromiso
        </p>
        <p class="text-paragraphs text-primary flex items-center gap-2 font-medium">
          <i><img src="/icons/check.svg" alt="check icon" class="w-[80%]" /></i>Profesionalismo
        </p>
        <p class="text-paragraphs text-primary flex items-center gap-2 font-medium">
          <i><img src="/icons/check.svg" alt="check icon" class="w-[80%]" /></i>Enfoque en resultados
        </p>
      </div>
      <div>
        <Button href="#servicios">Oferta de servicios</Button>
      </div>
    </div>
  </section>

  <!-- Serives section -->
  <section id="servicios" class="relative bg-black text-white" style={`height: calc(100vh * ${SERVICES.length})`}>
    <div class="sticky top-0 h-screen w-full overflow-hidden">
      {
        SERVICES.map((service) => (
          <Service
            title={service.title}
            description={service.description}
            details={service.details}
            index={SERVICES.indexOf(service)}
          />
        ))
      }
      <div class="absolute top-1/2 right-6 z-10 hidden -translate-y-1/2 flex-col gap-3 md:flex">
        {
          SERVICES.map((_, i) => (
            <button
              class="service-dot h-2.5 w-2.5 cursor-pointer rounded-full border border-white/60 bg-transparent transition-all duration-300"
              data-dot={i}
              aria-label={`Go to service ${i + 1}`}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Quote form section -->
  <section id="contacto" class="mx-layout my-10 flex flex-col space-y-4 md:flex-row md:items-center md:gap-10">
    <div class="w-full md:w-1/2">
      <h2 class="text-titles-2 text-primary font-semibold">Solicita una cotización</h2>
      <div class="mt-10 flex h-full items-center gap-6">
        <img src="/icons/process_contact.svg" alt="Process bar" />
        <div class="flex h-full flex-col space-y-14">
          <div class="flex items-center gap-4">
            <img src="/img/form.webp" alt="form image" class="h-20.5 w-auto" />
            <p class="text-primary text-sm">Rellena el formulario y cuentanos sobre tu proyecto</p>
          </div>
          <div class="flex items-center gap-4">
            <img src="/img/support.webp" alt="support image" class="h-20.5 w-auto" />
            <p class="text-primary text-sm">Nos pondremos en contacto contigo por seguimiento</p>
          </div>
          <div class="flex items-center gap-4">
            <img src="/img/quote.webp" alt="quote image" class="h-20.5 w-auto" />
            <p class="text-primary text-sm">Recibe una cotización</p>
          </div>
        </div>
      </div>
      <p class="text-primary mt-10 text-sm">
        Nuestro proceso es rápido y sencillo. Cuéntanos lo que necesitas, te contactamos para afinar los detalles y
        recibirás una cotización personalizada en el menor tiempo posible.
      </p>
    </div>
    <div class="w-full md:w-1/2">
      <QuoteForm />
    </div>
  </section>
</Layout>

<script>
  const section = document.getElementById("servicios")!;
  const panels = document.querySelectorAll<HTMLElement>(".servicio-panel");
  const dots = document.querySelectorAll<HTMLElement>(".service-dot");
  const total = panels.length;
  let currentIndex = 0;

  function goTo(targetIndex: number) {
    if (targetIndex === currentIndex) {
      return;
    }
    panels[currentIndex].style.opacity = "0";
    panels[currentIndex].style.pointerEvents = "none";
    dots[currentIndex]?.classList.remove("bg-white", "scale-125");
    panels[targetIndex].style.opacity = "1";
    panels[targetIndex].style.pointerEvents = "auto";
    dots[targetIndex]?.classList.add("bg-white", "scale-125");

    currentIndex = targetIndex;
  }

  // Initialize first dot
  dots[0]?.classList.add("bg-white", "scale-125");

  // Dot click navigation
  dots.forEach((dot, i) => {
    dot.addEventListener("click", () => {
      const sectionTop = section.getBoundingClientRect().top + window.scrollY;
      const targetScroll = sectionTop + window.innerHeight * i;
      window.scrollTo({ top: targetScroll, behavior: "smooth" });
    });
  });

  // Scroll-driven panel switching
  window.addEventListener(
    "scroll",
    () => {
      const rect = section.getBoundingClientRect();
      const sectionHeight = section.offsetHeight - window.innerHeight;
      const scrolled = -rect.top;

      if (scrolled < 0 || scrolled > sectionHeight) {
        return;
      }

      const progress = scrolled / sectionHeight; // 0 → 1
      const targetIndex = Math.min(Math.floor(progress * total), total - 1);

      goTo(targetIndex);
    },
    { passive: true },
  );
</script>
