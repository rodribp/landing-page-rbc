---
import Layout from "@/layouts/Layout.astro";
import "@/styles/animations.css";
import Button from "@/components/atoms/Button.astro";
import Service from "@/components/Service.astro";
import { CONTACT_EMAIL } from "@/utils/global_variables";
import { SERVICES } from "@/utils/services";
const url = Astro.url;
---

<Layout>
  <section
    class="relative h-screen bg-cover bg-fixed bg-left bg-no-repeat md:bg-center"
    style="background-image: url('/img/inicio.webp')"
  >
    <div
      class="mx-layout absolute top-1/2 left-0 block w-3/4 -translate-y-[70%] md:w-1/2 lg:w-1/3"
    >
      <h1 class="text-titles animate-fade-up mb-4 text-white delay-100">
        Hacemos realidad tus proyectos
      </h1>
      <h3 class="text-subtitles animate-fade-up mb-4 text-white delay-400">
        Expertos en servicios profesionales en el área de la construcción.
      </h3>
      <Button href="#contacto" class="fade-in-on-load">¡Cotiza ya!</Button>
    </div>
    <!-- Boton sobre nosotros -->
    <a
      href="#sobre-nosotros"
      class="animate-bounce-slow pause-on-hover absolute bottom-5 flex w-full flex-col items-center justify-center space-y-2 text-white delay-800"
    >
      <p class="drop-shadow-[0_0_6px_rgba(255,255,255,1)]">Sobre Nosotros</p>
      <img src="/icons/arrowdown.svg" alt="arrow down" />
    </a>
  </section>

  <section
    class="mx-layout relative my-10 flex flex-col items-center justify-center text-center"
  >
    <p class="text-paragraphs text-primary">
      Nuestros servicios han estado presentes en diferentes proyectos y empresas
    </p>
    <div class="mt-5 flex flex-row flex-wrap items-center justify-center gap-4">
      <img
        src="/trusted_companies/1.png"
        alt="Compañia 1"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/2.png"
        alt="Compañia 2"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/3.png"
        alt="Compañia 3"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/4.png"
        alt="Compañia 4"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/5.png"
        alt="Compañia 5"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/6.png"
        alt="Compañia 6"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/7.png"
        alt="Compañia 7"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
      <img
        src="/trusted_companies/8.png"
        alt="Compañia 8"
        class="h-auto w-[20%] object-contain md:w-[16%]"
      />
    </div>
  </section>

  <section
    id="sobre-nosotros"
    class="mx-layout relative my-10 flex flex-col space-y-4 lg:flex-row lg:gap-15"
  >
    <img
      src="/img/collage.webp"
      alt="Collage img"
      class="h-auto w-full lg:w-[45%]"
    />
    <div class="flex flex-col justify-center space-y-6">
      <h2 class="text-titles-2 text-primary">
        <span class="font-semibold">Tu aliado estratégico</span> para ejecutar tus
        proyectos
      </h2>
      <p class="text-paragraphs text-primary">
        Somos una empresa salvadoreña con amplia experiencia en el sector de la
        construcción, especializada en soluciones integrales de ingeniería.
      </p>
      <div class="flex flex-col justify-center space-y-4">
        <p
          class="text-paragraphs text-primary flex items-center gap-2 font-medium"
        >
          <i><img src="/icons/check.svg" alt="check icon" class="w-[80%]" /></i
          >Compromiso
        </p>
        <p
          class="text-paragraphs text-primary flex items-center gap-2 font-medium"
        >
          <i><img src="/icons/check.svg" alt="check icon" class="w-[80%]" /></i
          >Profesionalismo
        </p>
        <p
          class="text-paragraphs text-primary flex items-center gap-2 font-medium"
        >
          <i><img src="/icons/check.svg" alt="check icon" class="w-[80%]" /></i
          >Enfoque en resultados
        </p>
      </div>
      <div>
        <Button href="#servicios">Oferta de servicios</Button>
      </div>
    </div>
  </section>

  <section id="servicios" class="my-10 text-white">
    <!-- Servicio 1 -->
    {
      SERVICES.map((service) => (
        <Service
          title={service.title}
          description={service.description}
          details={service.details}
          index={SERVICES.indexOf(service)}
        />
      ))
    }
  </section>

  <section
    id="contacto"
    class="mx-layout my-10 flex flex-col space-y-4 md:flex-row md:items-center md:gap-10"
  >
    <div class="w-full md:w-1/2">
      <h2 class="text-titles-2 text-primary font-semibold">
        Solicita una cotización
      </h2>
      <div class="mt-10 flex h-full items-center gap-6">
        <img src="/icons/process_contact.svg" alt="Process bar" />
        <div class="flex h-full flex-col space-y-14">
          <div class="flex items-center gap-4">
            <img
              src="/img/form.webp"
              alt="form image"
              class="h-[82px] w-auto"
            />
            <p class="text-primary text-sm">
              Rellena el formulario y cuentanos sobre tu proyecto
            </p>
          </div>
          <div class="flex items-center gap-4">
            <img
              src="/img/support.webp"
              alt="support image"
              class="h-[82px] w-auto"
            />
            <p class="text-primary text-sm">
              Nos pondremos en contacto contigo por seguimiento
            </p>
          </div>
          <div class="flex items-center gap-4">
            <img
              src="/img/quote.webp"
              alt="quote image"
              class="h-[82px] w-auto"
            />
            <p class="text-primary text-sm">Recibe una cotización</p>
          </div>
        </div>
      </div>
      <p class="text-primary mt-10 text-sm">
        Nuestro proceso es rápido y sencillo. Cuéntanos lo que necesitas, te
        contactamos para afinar los detalles y recibirás una cotización
        personalizada en el menor tiempo posible.
      </p>
    </div>
    <div class="mt-5 w-full md:mt-0 md:w-1/2">
      <form
        id="cotizacion"
        action=`https://formsubmit.co/${CONTACT_EMAIL}`
        method="POST"
        class="flex flex-wrap gap-4"
      >
        <div class="block w-[47%] md:w-[45%]">
          <label for="nombre" class="text-sm"
            >Nombres<span class="text-red-500">*</span></label
          >
          <input
            type="text"
            maxlength="30"
            id="nombre"
            name="nombre"
            class="h-8 w-full bg-black/20"
            required
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="apellido" class="text-sm"
            >Apellidos<span class="text-red-500">*</span></label
          >
          <input
            type="text"
            maxlength="30"
            id="apellido"
            name="apellido"
            class="h-8 w-full bg-black/20"
            required
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="correo" class="text-sm"
            >Correo electrónico <span class="text-red-500">*</span></label
          >
          <input
            type="email"
            maxlength="50"
            id="correo"
            name="correo"
            class="h-8 w-full bg-black/20"
            required
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="telefono" class="text-sm">Teléfono</label>
          <input
            type="text"
            maxlength="16"
            id="telefono"
            name="telefono"
            class="h-8 w-full bg-black/20"
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="empresa" class="text-sm"
            >Empresa <span class="text-red-500">*</span></label
          >
          <input
            type="text"
            maxlength="25"
            id="empresa"
            name="empresa"
            class="h-8 w-full bg-black/20"
            required
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="cargo" class="text-sm">Cargo</label>
          <input
            type="text"
            maxlength="30"
            id="cargo"
            name="cargo"
            class="h-8 w-full bg-black/20"
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="industria" class="text-sm"
            >Industria <span class="text-red-500">*</span></label
          >
          <input
            type="text"
            maxlength="50"
            id="industria"
            name="industria"
            class="h-8 w-full bg-black/20"
            required
          />
        </div>
        <div class="block w-[47%] md:w-[45%]">
          <label for="servicios_interes" class="text-sm">
            Servicio de interés <span class="text-red-500">*</span>
          </label>

          <select
            id="servicios_interes"
            name="servicios_interes"
            class="h-8 w-full overflow-hidden bg-black/20 text-sm"
            required
          >
            <option value="metal_mecanica">Metal mecánica</option>
            <option value="estructuras_tuberias_maquinado"
              >Estructuras, tuberías y maquinado</option
            >
            <option value="electricidad"
              >Electricidad residencial e industrial</option
            >
          </select>
        </div>
        <div class="block w-[98%] md:w-[93%]">
          <label for="descripcion" class="text-sm"
            >Descripción <span class="text-red-500">*</span></label
          >
          <textarea
            id="descripcion"
            maxlength="500"
            name="descripcion"
            class="h-24 w-full bg-black/20"
            required></textarea>
          <p id="contador" class="text-right text-sm">0 / 500</p>
        </div>
        <input type="text" name="_honey" style="display:none" />
        <input type="hidden" name="_captcha" value="false" />
        <input
          type="hidden"
          name="_subject"
          value="Solicitud de cotización desde la web de RBC"
        />
        <input type="hidden" name="_next" value=`${url.href}#gracias` />
        <button
          class="inline-block cursor-pointer bg-black/60 p-2 px-6 text-lg font-semibold text-white duration-200 hover:bg-black/100"
          type="submit">Enviar</button
        >
      </form>
      <h2 id="gracias" class="text-titles-2 text-primary hidden font-semibold">
        Gracias por tu interés en nuestros servicios. Nos pondremos en contacto
        contigo lo más pronto posible.
      </h2>
    </div>
  </section>
</Layout>

<script>
  const textarea = document.getElementById("descripcion");
  const contador = document.getElementById("contador");

  textarea?.addEventListener("input", () => {
    contador.textContent = `${textarea.value.length} / ${textarea.maxLength}`;
  });

  const gracias = document.getElementById("gracias");
  const form = document.getElementById("cotizacion");

  if (window.location.hash === "#gracias") {
    form?.classList.add("hidden");
    gracias?.classList.remove("hidden");

    setTimeout(() => {
      gracias?.classList.add("hidden");
      form?.classList.remove("hidden");

      // Limpiar el hash para que no se quede pegado
      history.replaceState(
        null,
        "",
        window.location.pathname + window.location.search,
      );
    }, 5000);
  }
</script>
