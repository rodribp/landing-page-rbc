---
import "@/styles/global.css";
import Layout from "./Layout.astro";
---

<Layout>
  <section id="header" class="mx-layout text-primary my-10">
    <slot name="header" />
  </section>
  <section id="content" class="mx-layout text-primary mb-10">
    <slot name="content" />
  </section>
</Layout>

<style>
  /* Max width for images in content */
  section#content :global(img) {
    max-width: 650px;
  }

  /* H1 - not visible in mockup, keeping proportional */
  section :global(h1) {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
  }

  /* H2 - "Detalles del proyecto" */
  section :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  /* H3 - subsection labels */
  section :global(h3) {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    margin-top: 1.5rem;
  }

  /* Body paragraphs */
  section :global(p) {
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  /* Bullet lists */
  section :global(ul) {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }

  section :global(ol) {
    list-style: decimal;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }

  section :global(li) {
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 0.25rem;
  }

  /* Nested lists */
  section :global(li > ul),
  section :global(li > ol) {
    margin-top: 0.25rem;
    margin-bottom: 0;
  }

  /* Inline code */
  section :global(code) {
    font-family: monospace;
    font-size: 0.8rem;
    background-color: #f1f1f1;
    padding: 0.1em 0.4em;
    border-radius: 4px;
  }

  /* Code blocks */
  section :global(pre) {
    background-color: #f1f1f1;
    padding: 1rem;
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    line-height: 1.6;
  }

  section :global(pre code) {
    background: none;
    padding: 0;
  }

  /* Blockquotes */
  section :global(blockquote) {
    border-left: 3px solid currentColor;
    padding-left: 1rem;
    margin: 1rem 0;
    opacity: 0.7;
    font-style: italic;
  }

  /* Horizontal rule */
  section :global(hr) {
    border: none;
    border-top: 1px solid currentColor;
    opacity: 0.15;
    margin: 2rem 0;
  }

  /* Links */
  section :global(a) {
    text-decoration: underline;
    text-underline-offset: 3px;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  section :global(a:hover) {
    opacity: 1;
  }

  /* Tables */
  section :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  section :global(th) {
    font-weight: 700;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid currentColor;
  }

  section :global(td) {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid currentColor;
    opacity: 0.85;
  }

  /* Images inside MD */
  section :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 4px;
    margin: 1rem 0;
  }

  /* Bold & italic */
  section :global(strong) {
    font-weight: 700;
  }

  section :global(em) {
    font-style: italic;
  }
</style>
