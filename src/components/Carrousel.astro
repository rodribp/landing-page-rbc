---
import { getCollection } from "astro:content";

const projects = (await getCollection("proyectos")).filter((p) => p.data.publishedAt);
---

<div>
  <!-- Track -->
  <div class="h-auto w-full overflow-hidden">
    <div id="carousel-track" class="flex h-auto gap-3 transition-transform duration-500 ease-in-out">
      {
        projects.map((project, i) => (
          <a
            href={`/proyectos/${project.slug}`}
            class="group relative h-64 w-[48%] shrink-0 cursor-pointer overflow-hidden md:h-120 md:w-[33%]"
          >
            <img
              src={project.data.image}
              alt={project.data.title}
              class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
            <p class="absolute right-4 bottom-4 left-4 text-xl leading-snug font-bold text-white">{project.data.title}</p>
          </a>
        ))
      }
    </div>
  </div>
  <!-- Arrows -->
  <div class="mt-4 flex gap-3 px-1">
    <button
      id="carousel-prev"
      class="flex h-9 w-9 items-center justify-center rounded-full border border-gray-400 text-gray-600 transition hover:border-black hover:text-black disabled:opacity-30"
      aria-label="Anterior"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M15 18l-6-6 6-6"></path>
      </svg>
    </button>
    <button
      id="carousel-next"
      class="flex h-9 w-9 items-center justify-center rounded-full border border-gray-400 text-gray-600 transition hover:border-black hover:text-black disabled:opacity-30"
      aria-label="Siguiente"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M9 18l6-6-6-6"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  // Carrousel:

  const track = document.getElementById("carousel-track")!;
  const prev = document.getElementById("carousel-prev") as HTMLButtonElement;
  const next = document.getElementById("carousel-next") as HTMLButtonElement;

  const cards = track.children;
  let index = 0;

  function getVisible() {
    // How many cards are visible based on card min-width
    return window.innerWidth >= 640 ? 3 : 2;
  }

  function maxIndex() {
    return cards.length - getVisible();
  }

  function update() {
    const cardWidth = (cards[0] as HTMLElement).offsetWidth;
    const gap = 12; // gap-3 = 12px
    const px = Array.from(cards)
      .slice(0, index)
      .reduce((acc, card) => acc + (card as HTMLElement).offsetWidth + gap, 0);
    track.style.transform = `translateX(-${px}px)`;
    prev.disabled = index === 0;
    next.disabled = index >= maxIndex();
  }

  prev.addEventListener("click", () => {
    index = Math.max(0, index - 1);
    update();
  });

  next.addEventListener("click", () => {
    index = Math.min(maxIndex(), index + 1);
    update();
  });

  window.addEventListener("resize", () => {
    index = Math.min(index, maxIndex());
    update();
  });
  update();
</script>
